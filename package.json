{
  "name": "aulia-apotek-klinik",
  "version": "1.0.0",
  "private": true,
  "description": "Aplikasi Apotek & Klinik Aulia",
  "scripts": {
    "build:css": "tailwindcss -i ./src/tailwind-input.css -o ./css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind-input.css -o ./css/tailwind.css --watch",
    "build": "npm run build:css",
    "start": "node server.js",
    "dev": "npm run build:css && node server.js",
    "lint": "echo 'No lint script configured'"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
